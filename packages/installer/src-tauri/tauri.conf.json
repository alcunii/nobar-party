{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "NobarParty",
  "version": "0.1.10",
  "identifier": "com.nobar-party.installer",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [{
      "title": "Nobar Party Installer",
      "width": 540,
      "height": 620,
      "resizable": false,
      "center": true
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "resources": ["resources/extension.zip"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
