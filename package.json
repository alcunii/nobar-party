{
  "name": "nobar-party",
  "version": "0.1.0",
  "private": true,
  "description": "Synchronized video watch-along Chrome extension + signaling server",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "test:e2e": "pnpm --filter @nobar-party/extension test:e2e",
    "lint": "pnpm -r --filter \"./packages/*\" lint",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
